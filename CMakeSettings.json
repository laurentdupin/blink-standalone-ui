      "inheritEnvironments": [ "clang_cl_x64_x64" ],
      "intelliSenseMode": "windows-clang-x64",
      "buildCommandArgs": "-j 8",
      "variables": [
        {
          "name": "CMAKE_C_COMPILER",
          "value": "clang-cl",
          "type": "STRING"
        },
        {
          "name": "CMAKE_CXX_COMPILER",
          "value": "clang-cl",
          "type": "STRING"
        }
      ]
